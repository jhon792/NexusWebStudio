# =============================================
# VARIABLES DE ENTORNO — John Dev
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git — está en .gitignore
# =============================================

# Google Analytics 4 — Measurement ID
# Formato: G-XXXXXXXXXX
# Obtenerlo en: analytics.google.com
VITE_GA4_ID=G-XXXXXXXXXX

# EmailJS — formulario de contacto
# Panel: https://dashboard.emailjs.com/admin
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
# Public Key: https://dashboard.emailjs.com/admin/account
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Google Search Console — verificación (opcional)
# VITE_GSC_VERIFICATION=xxxxxxxxxxxxxxxx

# URL base del sitio (para sitemap y canonical)
VITE_SITE_URL=https://johndev.com

# WhatsApp número de contacto (con código de país)
VITE_WA_NUMBER=573123198706
